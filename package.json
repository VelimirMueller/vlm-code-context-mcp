{
  "name": "code-context-mcp",
  "version": "1.0.0",
  "description": "MCP server that indexes codebases and exposes file metadata, exports, and dependency graphs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "code-context-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/dashboard.ts",
    "dashboard": "tsx src/dashboard.ts",
    "setup": "node dist/setup.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "private": false
}
