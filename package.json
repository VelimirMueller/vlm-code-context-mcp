{
  "name": "vlm-code-context-mcp",
  "version": "1.0.0",
  "description": "MCP server that indexes codebases and exposes file metadata, exports, and dependency graphs",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "code-context-mcp": "dist/server/setup.js",
    "code-context-dashboard": "dist/dashboard/dashboard.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp src/dashboard/dashboard.html dist/dashboard/",
    "start": "node dist/server/index.js",
    "dev": "tsx src/dashboard/dashboard.ts",
    "dashboard": "tsx src/dashboard/dashboard.ts",
    "setup": "node dist/server/setup.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "keywords": ["mcp", "code-context", "codebase-indexer", "model-context-protocol", "sqlite"],
  "repository": {
    "type": "git",
    "url": "https://github.com/VelimirMueller/mcp-server"
  },
  "license": "MIT"
}
